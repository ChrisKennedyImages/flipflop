# Copy this file to `secrets.toml` and fill in real values.
# DO NOT commit secrets.toml to git (it is in .gitignore).

ANTHROPIC_API_KEY = "sk-ant-..."

# --- Optional: Google Sheets sync ---
# Share the sheet with the service-account `client_email` as Editor.

# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "flipflow@your-project.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."

# [flipflow]
# sheet_id = "your-google-sheet-id"
# worksheet = "items"
